# 生产环境务必设置（Render 等平台在 Environment 中配置）
JWT_SECRET=your-random-secret-at-least-32-chars
JWT_REFRESH_SECRET=another-random-refresh-secret

# Postgres 连接串（Render Postgres / 任意 Postgres）
# DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DBNAME

# 可选：端口（Render 自动注入 PORT）
# PORT=3000

# 可选：启动时自动创建演示账号（避免每次手动注册 client / influencer）
# - 默认开启：SEED_DEMO_USERS=1
# - 关闭：SEED_DEMO_USERS=0
# SEED_DEMO_USERS=1
# SEED_CLIENT_USERNAME=client002
# SEED_CLIENT_PASSWORD=123456
# SEED_INFLUENCER_USERNAME=influencer002
# SEED_INFLUENCER_PASSWORD=123456

# 若使用翻译/朗读功能再配置
# DEEPSEEK_API_KEY=
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=
